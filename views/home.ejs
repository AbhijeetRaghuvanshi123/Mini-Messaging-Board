<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="container">
        <h1>📬 Message Dashboard</h1>
        <h1 style="font-size:1.2rem; margin: 0.5rem 0 1rem;">New Messages</h1>

        <% messages.forEach(message => { %>
            <div class="card">
                <div>
                    <h2>From: <%= message.user %></h2>
                    <h6>Date: <%= message.added %></h6>
                </div>
                <button><a href="/view?user=<%= message.user %>">View</a></button>
            </div>
        <% }) %>

        <div style="margin-top: 1.5rem;">
            <button><a href="/new">+ New Message</a></button>
        </div>
    </div>
</body>
</html>