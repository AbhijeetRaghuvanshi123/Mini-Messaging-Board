<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>New Message</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="container">
        <h1 style="margin-bottom: 1.5rem;">✉️ New Message</h1>
        <form method="POST" action="/new">
            <label for="author-name">Sender Name</label>
            <input type="text" name="user" id="author-name" placeholder="Enter receiver's name">

            <label for="text-msg">Message</label>
            <input type="text" name="text" id="text-msg" placeholder="Type your message...">

            <button type="submit">Send Message</button>
        </form>
    </div>
</body>
</html>