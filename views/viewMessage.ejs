<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Message from <%= message.user %></title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="container">
        <h1 style="margin-bottom: 1.5rem;">📩 Message Detail</h1>
        <div class="message-detail">
            <h2>From: <%= message.user %></h2>
            <p><%= message.text %></p>
            <h3 style="font-size:0.9rem; color:#888;">📅 <%= message.added %></h3>
        </div>
        <div style="margin-top: 1.5rem;">
            <button><a href="/">← Back</a></button>
        </div>
    </div>
</body>
</html>